{
  "expo": {
    "name": "collectiv",
    "slug": "collectiv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "collectiv",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Collectiv needs access to your photos so you can add card images.",
          "cameraPermission": "Collectiv needs access to your camera so you can photograph your cards."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Collectiv needs camera access to scan your cards."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Collectiv uses your location to show nearby collectors, vendors, and events on the map.",
          "locationAlwaysAndWhenInUsePermission": "Collectiv uses your location to show nearby collectors, vendors, and events on the map."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
